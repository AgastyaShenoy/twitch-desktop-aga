{
  "name": "twitch-react-app",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build && node -e \"import('fs').then(fs => { const f = 'dist/index.html'; fs.writeFileSync(f, fs.readFileSync(f, 'utf8').replace(/ crossorigin/g, '')); })\" && electron-builder",
    "release": "vite build && node -e \"import('fs').then(fs => { const f = 'dist/index.html'; fs.writeFileSync(f, fs.readFileSync(f, 'utf8').replace(/ crossorigin/g, '')); })\" && electron-builder --win --publish always",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.twitch.antigravity",
    "productName": "Twitch Desktop App",
    "win": {
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AgastyaShenoy",
        "repo": "twitch-desktop-aga"
      }
    ]
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-player": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}